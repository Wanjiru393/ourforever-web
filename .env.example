# Copy to .env for local dev — set these as Environment Variables in Vercel dashboard for production

# Your deployed backend URL (e.g. https://invite-api.onrender.com)
VITE_API_URL=http://localhost:3001

# Hero background video (S3 or any public URL)
VITE_HERO_VIDEO_URL=

# Supabase — public anon key, safe for browser
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe publishable key (pk_live_... for production)
VITE_STRIPE_PUBLISHABLE_KEY=

# Sanity CMS
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
